# ─── Email delivery ───────────────────────────────────────────────────────────
# Resend API key — resend.com → API Keys
RESEND_API_KEY=re_XXXXXXXXXX
# Destination inboxes (optional overrides — defaults set in src/app/api/contact/route.ts)
EMAIL_DEMO_INBOX=demo@skinmap.com
EMAIL_PARTNERSHIPS_INBOX=partnerships@skinmap.com
EMAIL_INVESTORS_INBOX=investors@skinmap.com
EMAIL_GENERAL_INBOX=hello@skinmap.com
EMAIL_PRESS_INBOX=press@skinmap.com

# ─── Analytics — Phase 2 ──────────────────────────────────────────────────────
# GA4 measurement ID from Google Analytics > Admin > Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Product Analytics — Phase 4 ──────────────────────────────────────────────
# PostHog project API key (https://app.posthog.com/project/settings)
NEXT_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Error Monitoring — Phase 6 ───────────────────────────────────────────────
# Sentry DSN (https://sentry.io > Project Settings > Client Keys)
NEXT_PUBLIC_SENTRY_DSN=https://XXXXXXXX@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_ORG=skinmap
SENTRY_PROJECT=skinmap-web

# ─── Environments ─────────────────────────────────────────────────────────────
# Set in Vercel dashboard per environment:
#   Production  → NEXT_PUBLIC_APP_ENV=production
#   Preview     → NEXT_PUBLIC_APP_ENV=staging
#   Development → NEXT_PUBLIC_APP_ENV=development  (set in .env.local)
NEXT_PUBLIC_APP_ENV=development
# Canonical URL — used for sitemap.xml and robots.txt
NEXT_PUBLIC_SITE_URL=https://skinmap.com
